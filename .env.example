# RPC endpoint — any EVM chain with Safe contracts deployed
# Base Sepolia (free, recommended for testing):
RPC_URL=https://sepolia.base.org
CHAIN_ID=84532

# Safe address (2-of-2 multisig you control)
SAFE_ADDRESS=0xYourSafeAddress

# Owner private keys (NEVER commit real keys)
OWNER_1_PRIVATE_KEY=0x...
OWNER_2_PRIVATE_KEY=0x...

# Transaction target (for the example scripts)
RECIPIENT_ADDRESS=0xRecipientAddress
SEND_VALUE_WEI=100000000000000000
